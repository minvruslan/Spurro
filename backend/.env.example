DATABASE_URL=postgresql://spurro:spurro@localhost:5432/spurro
QUEUE_URL=redis://localhost:6379

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

ADMIN_EMAIL=
#ADMIN_NAME=Admin

# SSH identity of this (main) node — the public half is installed on every provisioned node.
# Generate once: ssh-keygen -t ed25519 -N '' -f app_ssh_key
# Paste the private key as a double-quoted multiline value or as a single line with \n escapes.
# Keep .env in backups: restoring the main node needs the database dump AND this file.
APP_SSH_PRIVATE_KEY=
# Public SSH key of your local machine (one authorized_keys line) — installed on every node
# so you can connect directly: ssh <service user>@<node ip>
#OPERATOR_SSH_PUBLIC_KEY=

# Public address of this (main) node — registered as the current server on startup.
IP=
# Country as ISO 3166-1 alpha-2 code, e.g. NL
COUNTRY=NL
#DOMAIN_NAME=
