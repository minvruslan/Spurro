{
  "name": "@spurro/backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/zod-validator": "^0.7.6",
    "@spurro/shared": "workspace:*",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fractional-indexing": "^3.2.0",
    "hono": "^4.7.10",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.5",
    "slugify": "^1.6.9",
    "transliteration": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
